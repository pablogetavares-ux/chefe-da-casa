# Chef da Casa AI — variáveis de ambiente
# Copie: cp .env.example .env
# Supabase: https://supabase.com/dashboard/project/mnevlegpkrncxlqkqdnl/settings/api

# --- Público (client + server) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Chef da Casa AI
NEXT_PUBLIC_SUPABASE_URL=https://mnevlegpkrncxlqkqdnl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- CAPTCHA (Cloudflare Turnstile + Supabase Attack Protection) ---
# Site key pública: https://dash.cloudflare.com/?to=/:account/turnstile
# Secret key: apenas no Supabase Dashboard → Auth → Attack Protection
# Deixe vazio em dev local se Attack Protection estiver desligado no Supabase.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Servidor (nunca expor no client) ---
SUPABASE_SERVICE_ROLE_KEY=
# Separar por vírgula; quem estiver aqui vê o menu Admin e /app/admin
ADMIN_EMAILS=admin@example.com

# --- Postgres remoto (migrations CLI — não commitar senha) ---
# DIRECT_URL=postgresql://postgres:****@db.mnevlegpkrncxlqkqdnl.supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=sbp_...  # https://supabase.com/dashboard/account/tokens

# --- IA ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
AI_DEV_MOCK=true

# --- Gemini (opcional, pós go-live — capas de receita) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
# RECIPE_IMAGES_ENABLED=true

# --- Billing (Stripe — web) ---
BILLING_DEV_MOCK=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_FAMILY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Billing mobile (RevenueCat + Google Play) ---
# Secret API key: RevenueCat Dashboard → Project → API keys
REVENUECAT_SECRET_KEY=
# Webhook authorization (Bearer) em Project → Integrations → Webhooks
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_ENTITLEMENT_PREMIUM=premium
# Chave pública Android (apps/mobile/.env): EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# --- Rate limit distribuído (recomendado produção) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Monitoramento (opcional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Prisma (build only; runtime usa Supabase Client) ---
DATABASE_URL=
DIRECT_URL=

# --- Deploy check (CI usa "ci" automaticamente) ---
# DEPLOY_CHECK_MODE=local|ci|production
#
# --- Produção (Vercel) ---
# Template completo: .env.production.example
# Validar: npm run deploy:check:prod && npm run production:check
