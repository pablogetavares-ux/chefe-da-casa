{
  "name": "chef-da-casa-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:here": "node scripts/prepare-dev.mjs && next dev -p 3000",
    "dev:local": "node scripts/dev-local.mjs",
    "sync:dev": "node scripts/sync-to-dev.mjs",
    "dev:mobile": "node scripts/kill-port.mjs 3000 && node scripts/dev-mobile.mjs",
    "mobile": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "dev:bg": "node scripts/dev-detached.mjs",
    "dev:fg": "node scripts/prepare-dev.mjs && next dev -p 3000",
    "dev:clean": "node scripts/dev-stop.mjs 3000 && node scripts/clean-next.mjs && node scripts/dev-detached.mjs",
    "dev:stop": "node scripts/dev-stop.mjs 3000",
    "dev:status": "node scripts/dev-status.mjs 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:check": "node scripts/check-deploy-env.mjs",
    "deploy:check:prod": "node scripts/check-deploy-env.mjs --production",
    "production:check": "node scripts/production-readiness.mjs",
    "launch:check": "node scripts/phase2-launch-check.mjs",
    "phase1:check": "node scripts/phase1-check.mjs",
    "setup:service-role": "node scripts/sync-service-role.mjs",
    "setup:service-role:paste": "node scripts/capture-service-role.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:types": "node scripts/sync-supabase-types.mjs",
    "db:types:mcp": "node scripts/apply-mcp-types.mjs",
    "db:supabase:push": "node scripts/push-supabase-migrations.mjs",
    "db:fix:offers-region": "node scripts/apply-supabase-sql.mjs supabase/migrations/20260530260000_regional_offers_geo_expansion.sql && node scripts/verify-offers-region.mjs",
    "setup:database-url": "node scripts/capture-database-url.mjs",
    "setup:access-token": "node scripts/capture-access-token.mjs",
    "integration:mcp": "node scripts/mcp-integration-check.mjs",
    "offers:sync-images": "node scripts/sync-offer-images.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:products": "node scripts/smoke-products.mjs",
    "test:substitutions": "node scripts/smoke-substitutions.mjs",
    "test:weekly-plan": "node scripts/smoke-weekly-plan.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=public",
    "test:e2e:public": "playwright test e2e/public.spec.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.13",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^6.39.0",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.100.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
