// Chef da Casa AI — Schema Prisma
// Fonte de verdade do domínio. Migrações aplicadas no Supabase PostgreSQL.
//
// RLS strategy (Supabase):
// - User-owned rows: user_id = (select auth.uid())
// - Nested rows (recipe_ingredients, shopping_list_items): ownership via parent FK
// - ingredients catalog: SELECT authenticated; INSERT/UPDATE own custom (created_by_id)
// - Service role bypasses RLS for webhooks (Stripe) and admin jobs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanTier {
  FREE
  PRO
  FAMILY
}

enum RecipeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum DietaryPreference {
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  LACTOSE_FREE
  LOW_CARB
  KETO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
  UNPAID
}

enum AiGenerationStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

// ─── Users (Supabase auth.users → public.profiles) ───────────────────────────

/// Application user profile. `id` matches Supabase `auth.users.id`.
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  bodyWeightKg  Decimal? @map("body_weight_kg") @db.Decimal(5, 2)
  bodyHeightCm  Decimal? @map("body_height_cm") @db.Decimal(5, 1)
  fitnessGoal   String?  @map("fitness_goal")
  seniorModeEnabled Boolean @default(false) @map("senior_mode_enabled")
  plan      PlanTier @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipes           Recipe[]
  pantryItems       PantryItem[]
  favorites         Favorite[]
  shoppingLists     ShoppingList[]
  subscriptions     Subscription[]
  aiGenerations     AiGeneration[]
  usageLogs         UsageLog[]
  customIngredients Ingredient[]   @relation("IngredientCreator")

  @@map("profiles")
}

// ─── Ingredients ─────────────────────────────────────────────────────────────

/// Global ingredient catalog. System entries + user-created custom items.
model Ingredient {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  category    String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy         User?              @relation("IngredientCreator", fields: [createdById], references: [id], onDelete: SetNull)
  recipeIngredients RecipeIngredient[]
  pantryItems       PantryItem[]
  shoppingListItems ShoppingListItem[]

  @@index([category])
  @@index([createdById])
  @@map("ingredients")
}

// ─── Recipes ─────────────────────────────────────────────────────────────────

model Recipe {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  title            String
  description      String?
  /// JSON snapshot for AI output / legacy display. Prefer `recipeIngredients` for structured data.
  ingredients      Json                @default("[]")
  instructions     Json                @default("[]")
  prepTimeMinutes  Int                 @default(0) @map("prep_time_minutes")
  cookTimeMinutes  Int                 @default(0) @map("cook_time_minutes")
  servings         Int                 @default(4)
  difficulty       RecipeDifficulty    @default(EASY)
  tags             String[]
  dietaryTags      DietaryPreference[] @map("dietary_tags")
  isAiGenerated    Boolean             @default(false) @map("is_ai_generated")
  aiPromptSnapshot String?             @map("ai_prompt_snapshot")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
  favorites         Favorite[]
  aiGenerations     AiGeneration[]

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([isAiGenerated])
  @@map("recipes")
}

model RecipeIngredient {
  id           String   @id @default(uuid()) @db.Uuid
  recipeId     String   @map("recipe_id") @db.Uuid
  ingredientId String   @map("ingredient_id") @db.Uuid
  quantity     Float?
  unit         String?
  notes        String?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

// ─── Pantry ──────────────────────────────────────────────────────────────────

model PantryItem {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  ingredientId String?   @map("ingredient_id") @db.Uuid
  name         String
  quantity     Float?
  unit         String?
  category     String?
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ingredientId])
  @@index([userId, expiresAt])
  @@map("pantry_items")
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  recipeId  String   @map("recipe_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
  @@index([recipeId])
  @@map("favorites")
}

// ─── Shopping lists ──────────────────────────────────────────────────────────

model ShoppingList {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @default("Lista de compras")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String   @id @default(uuid()) @db.Uuid
  shoppingListId String   @map("shopping_list_id") @db.Uuid
  ingredientId   String?  @map("ingredient_id") @db.Uuid
  name           String
  quantity       Float?
  unit           String?
  isChecked      Boolean  @default(false) @map("is_checked")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  ingredient   Ingredient?  @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@index([shoppingListId])
  @@index([ingredientId])
  @@map("shopping_list_items")
}

// ─── Subscriptions (Stripe) ──────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  stripeCustomerId     String             @map("stripe_customer_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  plan                 PlanTier           @default(FREE)
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ─── AI generations ──────────────────────────────────────────────────────────

model AiGeneration {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  recipeId         String?            @map("recipe_id") @db.Uuid
  model            String
  status           AiGenerationStatus @default(PENDING)
  promptTokens     Int                @default(0) @map("prompt_tokens")
  completionTokens Int                @default(0) @map("completion_tokens")
  totalTokens      Int                @default(0) @map("total_tokens")
  inputSnapshot    Json               @default("{}") @map("input_snapshot")
  outputSnapshot   Json?              @map("output_snapshot")
  errorMessage     String?            @map("error_message")
  latencyMs        Int?               @map("latency_ms")
  createdAt        DateTime           @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([recipeId])
  @@index([status])
  @@map("ai_generations")
}

// ─── Usage logs (audit / billing helpers) ────────────────────────────────────

model UsageLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt(sort: Desc)])
  @@map("usage_logs")
}
